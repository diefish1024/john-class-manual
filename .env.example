# ============================================================
# oauth2-proxy 环境变量示例
# 部署前：cp .env.example .env  并填入真实值
# ============================================================

# 交大 jAccount OIDC 配置
# jAccount OIDC Discovery 地址（以实际文档为准）
OIDC_ISSUER_URL=https://jaccount.sjtu.edu.cn/oauth2/

# 在 jAccount 开发者平台申请的 Client ID / Secret
OAUTH2_CLIENT_ID=your-client-id-here
OAUTH2_CLIENT_SECRET=your-client-secret-here

# Cookie 加密密钥（随机 32 字节 Base64）
# 生成命令：python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
OAUTH2_COOKIE_SECRET=REPLACE_WITH_RANDOM_32_BYTE_BASE64_STRING
